.listingsCard{
    list-style: none;
    font-size: 500;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

.movieImage{
    border-radius: 10px;
    background-color: azure;
}

.movieImage:hover{
    opacity: 0.5;
}

.listingsGrid{
    display: grid;
    grid-template-columns: repeat(auto-fill,230px);
    gap: 10rem;
    padding: 5rem;
    justify-content: center;
}

@media screen and (max-width: 600px){
    .listingsGrid{
        width:100%;
        height: auto;
    } 
}